{
    "$schema": "https://json.schemastore.org/tsconfig",
    "display": "NestJS",
    "extends": "./base.json",
    "compilerOptions": {
        "module": "CommonJS",
        "moduleResolution": "node",
        "target": "ES2021",
        "lib": [
            "ES2021"
        ],
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "sourceMap": true,
        "outDir": "./dist",
        "incremental": true,
        "baseUrl": "."
    },
    "exclude": [
        "node_modules",
        "dist",
        "test",
        "**/*spec.ts"
    ]
}