{
    "$schema": "https://json.schemastore.org/tsconfig",
    "extends": "../../packages/config/tsconfig/nextjs.json",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@/components/*": [
                "./src/components/*"
            ],
            "@/lib/*": [
                "./src/lib/*"
            ],
            "@/hooks/*": [
                "./src/hooks/*"
            ],
            "@/store/*": [
                "./src/store/*"
            ],
            "@/features/*": [
                "./src/features/*"
            ]
        }
    },
    "include": [
        "next-env.d.ts",
        "**/*.ts",
        "**/*.tsx",
        ".next/types/**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}